**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# ─────────────────────────────────────────────
# Virtual Environments
# ─────────────────────────────────────────────
venv/
env/
.env/
.venv/
ENV/

# ─────────────────────────────────────────────
# Environment Variables
# ─────────────────────────────────────────────
.env
.env.local
.env.production
*.env

# ─────────────────────────────────────────────
# Trained Models (large files)
# ─────────────────────────────────────────────
models/trained_models/*.pth
models/trained_models/*.pt
models/trained_models/*.pkl
!models/trained_models/.gitkeep

# ─────────────────────────────────────────────
# Data Files
# ─────────────────────────────────────────────
data/*.csv
data/*.pkl
data/*.parquet
data/*.h5
data/*.xlsx
!data/.gitkeep

# ─────────────────────────────────────────────
# Results & Logs
# ─────────────────────────────────────────────
results/
logs/
*.log
!results/.gitkeep
!logs/.gitkeep

# ─────────────────────────────────────────────
